generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  UserName        String            @unique
  email           String            @unique
  password        String?
  xp              Int               @default(0)
  level           Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isVerified      Boolean           @default(false)
  provider        String?
  providerId      String?
  isAdmin         Boolean           @default(false)
  banUntil        DateTime?
  isBanned        Boolean           @default(false)
  profilePicture  String?
  timezone        String            @default("UTC")
  tokens          Int               @default(50)
  hasOnboarded    Boolean           @default(false)
  AIChatHistory   AIChatHistory[]
  Clan            Clan[]
  Community       Community[]
  CommunityMember CommunityMember[]
  keys            Key[]
  messages        Message[]         @relation("senderMessages")
  otps            Otp[]
  Quest           Quest[]
  sessions        Session[]
  Ticket          Ticket[]
  onboarding      UserOnboarding?
  ClanMember      ClanMember[]
  category        Category[]        @relation("CategoryToUser")
  purchasedPlans  PurchasedPlan[]
  subscription    Subscription?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Key {
  id             String    @id
  userId         String
  hashedPassword String?
  expiresAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  createdBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  communities     Community[]
  users           User[]           @relation("CategoryToUser")
  userOnboardings UserOnboarding[] @relation("CategoryToUserOnboarding")
}

model Otp {
  id        String   @id @default(cuid())
  otp_code  String
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Community {
  id            String            @id @default(cuid())
  name          String            @unique
  description   String?
  createdAt     DateTime          @default(now())
  ownerId       String
  categoryId    String?
  updatedAt     DateTime          @updatedAt
  isPrivate     Boolean           @default(false)
  memberLimit   Int               @default(100)
  photo         String?
  xp            Int               @default(0)
  codeUpdatedAt DateTime?
  inviteCode  String?           @unique
  level         Int               @default(1)
  clans         Clan[]
  category      Category?         @relation(fields: [categoryId], references: [id])
  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       CommunityMember[]
  messages      Message[]
  quests        Quest[]
  clanMembers   ClanMember[]
}

model Clan {
  id             String       @id @default(cuid())
  name           String       @unique
  slug           String?      @unique // URL-friendly version of name
  isPrivate      Boolean      @default(false)
  xp             Int          @default(0)
  level          Int          @default(1)
  description    String?
  ownerId        String
  communityId    String
  limit          Int          @default(50)
  welcomeMessage String?
  stats          Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  joinCodeHash  String?           @unique

  community Community    @relation(fields: [communityId], references: [id])
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members   ClanMember[]
  messages  Message[]
}

model CommunityMember {
  id          String       @id @default(cuid())
  userId      String
  communityId String
  joinedAt    DateTime     @default(now())
  totalXP     Int          @default(0)
  level       Int          @default(1)
  status      MemberStatus @default(Beginner)
  role        Role         @default(MEMBER)
  isPinned    Boolean      @default(false)
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest       Quest[]

  @@unique([userId, communityId])
}

model ClanMember {
  id          String    @id @default(cuid())
  userId      String
  clanId      String
  communityId String
  joinedAt    DateTime  @default(now())
  totalXP     Int       @default(0)
  clan        Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clanId])
  @@index([userId, communityId])
  @@map("clanMember")
}

model Quest {
  id                String           @id @default(cuid())
  userId            String
  xpValue           Int
  isCompleted       Boolean          @default(false)
  date              DateTime
  createdAt         DateTime         @default(now())
  type              QuestType        @default(Daily)
  communityMemberId String?
  description       String
  source            QuestSource      @default(AI)
  periodKey         String?
  periodStatus      PeriodStatus     @default(NONE)
  periodSeq         Int              @default(0)
  communityId       String?
  completedAt       DateTime?
  estimatedMinutes  Int              @default(30)
  startedAt         DateTime?
  viewedAt          DateTime?
  community         Community?       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  CommunityMember   CommunityMember? @relation(fields: [communityMemberId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, communityId, type, date])
}

model Ticket {
  id                       String         @id @default(cuid())
  userId                   String
  subject                  SubjectType
  message                  String
  status                   TicketStatus   @default(PENDING)
  priority                 TicketPriority @default(LOW)
  expectedDateOfCompletion DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id          String     @id @default(uuid())
  communityId String?
  senderId    String
  content     String
  createdAt   DateTime   @default(now())
  clanId      String?
  clan        Clan?      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sender      User       @relation("senderMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model AIChatHistory {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String?
  prompt       String
  response     String
  tokensUsed   Int      @default(1)
  responseTime Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId])
}

model UserOnboarding {
  id           String      @id @default(cuid())
  userId       String      @unique
  heardAboutUs String?
  goal         String?
  experience   Experience?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories   Category[]  @relation("CategoryToUserOnboarding")
}

enum Role {
  MEMBER
  ADMIN
}

enum MemberStatus {
  Beginner
  Intermediate
  Advanced
}

enum QuestType {
  Daily
  Weekly
  Monthly
  OneTime
}

enum QuestSource {
  AI
  TEMPLATE
  MANUAL
}

enum PeriodStatus {
  TODAY
  YESTERDAY
  DAY_BEFORE_YESTERDAY
  THIS_WEEK
  LAST_WEEK
  TWO_WEEKS_AGO
  NONE
}

enum TicketStatus {
  PENDING
  WORKING_ON
  TO_BE_DONE_LATER
  APPROVED
  REJECTED
  CANCELLED
}

enum SubjectType {
  ACCOUNT_ISSUE
  PAYMENT_ISSUE
  BUG_REPORT
  FEATURE_REQUEST
  PERFORMANCE_ISSUE
  COMMUNITY_MANAGEMENT
  CLAN_MANAGEMENT
  QUEST_MANAGEMENT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Experience {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PurchaseStatus {
  pending
  completed
  refunded
}

enum PaymentMethod {
  khalti
}

enum PaymentGateway {
  khalti
  esewa
  connectIps
}

enum PaymentStatus {
  success
  pending
  failed
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

model SubscriptionPlan {
  id            String          @id @default(cuid())
  planName      String          @unique
  durationMonth Int
  price         Int
  features      String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  purchasedPlans PurchasedPlan[]
  subscriptions  Subscription[]

  @@map("SubscriptionPlan")
}

model PurchasedPlan {
  id            String         @id @default(cuid())
  userId        String
  planId        String
  totalPrice    Int
  purchaseDate  DateTime       @default(now())
  paymentMethod PaymentMethod
  status        PurchaseStatus @default(pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  payments      Payment[]

  @@index([userId])
  @@index([status])
  @@map("PurchasedPlan")
}

model Payment {
  id                        String         @id @default(cuid())
  transactionId             String?        @unique
  pidx                      String?        @unique
  productId                 String
  amount                    Int
  dataFromVerificationReq   Json?
  apiQueryFromUser          Json?
  paymentGateway            PaymentGateway
  status                    PaymentStatus  @default(pending)
  paymentDate               DateTime       @default(now())
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  purchasedPlan             PurchasedPlan  @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([status])
  @@map("Payment")
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  planId      String
  startDate   DateTime
  endDate     DateTime
  status      SubscriptionStatus @default(active)
  purchaseId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([endDate])
  @@map("Subscription")
}
