generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------
// User
// ----------------------------
model User {
  id         Int      @id @default(autoincrement())
  UserName   String   @unique
  email      String   @unique
  password   String
  isVerified Boolean  @default(false)
  xp         Int      @default(0)
  level      Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  categoryId      Int?
  category        Category?         @relation(fields: [categoryId], references: [id])
  otps            Otp[]
  Community       Community[]
  CommunityMember CommunityMember[]
  Clan            Clan[] // Clans owned by this user
  Quest           Quest[] // Quests assigned to user
}

// ----------------------------
// Category (Dynamic)
// ----------------------------
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdBy   Int? // User who created it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  users       User[]
  communities Community[]
}

// ----------------------------
// OTP (Authentication)
// ----------------------------
model Otp {
  id        Int      @id @default(autoincrement())
  otp_code  String
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

// ----------------------------
// Community
// ----------------------------
model Community {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  ownerId     Int
  categoryId  Int?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  // Relationships
  owner    User              @relation(fields: [ownerId], references: [id])
  category Category?         @relation(fields: [categoryId], references: [id])
  members  CommunityMember[]
  clans    Clan[]
}

// ----------------------------
// Clan
// ----------------------------
model Clan {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  isPrivate   Boolean  @default(false)
  xp          Int      @default(0)
  description String?
  ownerId     Int
  communityId Int
  limit       Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  owner     User              @relation(fields: [ownerId], references: [id])
  community Community         @relation(fields: [communityId], references: [id])
  members   CommunityMember[]
}

// ----------------------------
// Community Member
// ----------------------------
model CommunityMember {
  id          Int          @id @default(autoincrement())
  userId      Int
  communityId Int
  status      MemberStatus @default(Beginner)
  level       Int          @default(1)
  totalXP     Int          @default(0)
  clanId      Int?
  joinedAt    DateTime     @default(now())

  // Relationships
  quest     Quest[]
  community Community @relation(fields: [communityId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  clan      Clan?     @relation(fields: [clanId], references: [id])
}

// ----------------------------
// Quest
// ----------------------------
model Quest {
  id                Int         @id @default(autoincrement())
  userId            Int
  description       String
  xpValue           Int
  isCompleted       Boolean     @default(false)
  date              DateTime
  createdAt         DateTime    @default(now())
  type              QuestType   @default(Daily)
  source            QuestSource @default(AI)
  communityMemberId Int?

  // Relationships
  user            User             @relation(fields: [userId], references: [id])
  CommunityMember CommunityMember? @relation(fields: [communityMemberId], references: [id])
}

// ----------------------------
// Enums
// ----------------------------
enum MemberStatus {
  Beginner
  Intermediate
  Advanced
}

enum QuestType {
  Daily
  Weekly
  Monthly
  OneTime
}

enum QuestSource {
  AI
  TEMPLATE
  MANUAL
}
