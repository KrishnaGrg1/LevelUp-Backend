
# Example .env file for LevelUp Backend
# Copy this file to .env and fill in the required values
# Database connection string
# Note: Ensure to replace the values with your actual database credentials
# Example configuration for PostgreSQL database
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"
# Note: Replace username, password, host, port, and database with your actual database credentials
# Example JWT secret
JWT_SECRET="your_jwt_secret_password"
# Note: Ensure to replace the above values with your actual JWT secret password
# Port for the application to run on
PORT=8080
# Note: Change the port number as needed    
# Example SMTP configuration
# Note: Ensure to replace the above values with your actual configuration.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USERNAME="example_user"
SMTP_PASSWORD="example_password"

# OAuth Configuration for Google Authentication
# Note: Get these from Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/eng/auth/callback"

# OAuth Configuration for GitHub Authentication
# Note: Create a GitHub OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:3000/eng/auth/callback"

# Cloudinary configuration for file uploads
# Note: Get these credentials from your Cloudinary dashboard (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"



OPENAI_API_KEY="your openrouter api key"
MODEL_NAME="your model name"